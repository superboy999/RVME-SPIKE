prefix=/cluster/home/geyh/RV/riscv_tool/riscv_isa_sim/riscv-isa-sim/opt
exec_prefix=/cluster/home/geyh/RV/riscv_tool/riscv_isa_sim/riscv-isa-sim/opt
libdir=${exec_prefix}/lib
